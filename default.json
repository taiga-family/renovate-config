{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "allowCustomCrateRegistries": true,
    "allowScripts": true,
    "allowedCommands": [".*"],
    "autoApprove": true,
    "automerge": false,
    "baseBranchPatterns": ["main"],
    "branchConcurrentLimit": 2,
    "branchPrefix": "renovate/",
    "cloneSubmodules": true,
    "commitMessageLowerCase": "auto",
    "dependencyDashboard": false,
    "dependencyDashboardApproval": false,
    "digest": {
        "enabled": false
    },
    "enabledManagers": [
        "npm",
        "bun",
        "gitlabci",
        "dockerfile",
        "github-actions"
    ],
    "exposeAllEnv": true,
    "extends": [":semanticCommitScopeDisabled", "helpers:pinGitHubActionDigests"],
    "fetchChangeLogs": "off",
    "includePaths": [
        "**/package.json",
        "**/package-lock.json",
        "**/npm-shrinkwrap.json",
        "**/yarn.lock",
        "**/.yarnrc.yml",
        "**/pnpm-lock.yaml",
        "**/pnpm-workspace.yaml",
        "**/bun.lock",
        "**/bun.lockb",
        ".github/workflows/**",
        ".github/actions/**",
        ".gitea/workflows/**",
        ".forgejo/workflows/**",
        "**/action.yml",
        "**/action.yaml",
        "**/Dockerfile",
        "**/dockerfile",
        "**/Containerfile",
        "**/containerfile",
        "**/Dockerfile.*",
        "**/dockerfile.*",
        "**/Containerfile.*",
        "**/containerfile.*",
        ".gitlab-ci.yml",
        ".gitlab-ci.yaml",
        ".gitlab/**"
    ],
    "internalChecksFilter": "strict",
    "labels": [],
    "minimumReleaseAge": "14 days",
    "onboarding": false,
    "packageRules": [
        {
            "description": "Disable quarantine for trusted internal packages",
            "matchPackageNames": [
                "/^@maskito\\//",
                "/^@ng-web-apis\\//",
                "/^@taiga-ui\\//",
                "ng-morph"
            ],
            "minimumReleaseAge": null
        },
        {
            "enabled": false,
            "matchDepTypes": ["overrides"]
        },
        {
            "matchDepTypes": ["devDependencies", "dependencies"],
            "rangeStrategy": "pin"
        },
        {
            "matchDepTypes": ["peerDependencies", "optionalDependencies"],
            "rangeStrategy": "bump"
        },
        {
            "groupName": "tiptap",
            "matchPackageNames": ["/^@tiptap\\//"]
        },
        {
            "groupName": "playwright",
            "matchPackageNames": [
                "/^@playwright\\//",
                "@axe-core/playwright",
                "axe-playwright"
            ]
        },
        {
            "groupName": "maskito",
            "matchPackageNames": ["/^@maskito\\//"]
        },
        {
            "groupName": "cspell",
            "matchPackageNames": ["/^@cspell\\//"]
        },
        {
            "groupName": "prosemirror",
            "matchPackageNames": ["/^prosemirror.*/"]
        },
        {
            "groupName": "definitely typed",
            "matchPackageNames": ["/^@types\\//"]
        },
        {
            "groupName": "prettier",
            "matchPackageNames": [
                "/^prettier/",
                "/^@prettier\\//",
                "/^prettier-.*/"
            ]
        },
        {
            "groupName": "cypress",
            "matchPackageNames": [
                "/^cypress/",
                "/^cy2/",
                "/^cypress-.*/"
            ]
        },
        {
            "groupName": "commitlint",
            "matchPackageNames": ["/^@commitlint\\//"]
        },
        {
            "groupName": "release-it",
            "matchPackageNames": ["/^@release-it\\//", "/^release-it$/"]
        },
        {
            "groupName": "docsearch",
            "matchPackageNames": ["/^@docsearch\\//"]
        },
        {
            "groupName": "tinkoff",
            "matchPackageNames": ["/^@tinkoff\\//"]
        },
        {
            "groupName": "rollup",
            "matchPackageNames": ["/^rollup.*/", "@rollup/pluginutils"]
        },
        {
            "groupName": "swc",
            "matchPackageNames": ["/^@swc\\//"]
        },
        {
            "groupName": "stackblitz sdk",
            "matchPackageNames": ["/^@stackblitz\\//"]
        },
        {
            "groupName": "babel",
            "matchPackageNames": ["/^@babel\\/eslint-.*/", "/^babel.*/"]
        },
        {
            "groupName": "jest",
            "matchPackageNames": [
                "/^jest.*/",
                "/^ts-jest$/",
                "/^jest-preset-angular$/"
            ]
        },
        {
            "extends": ["monorepo:react"],
            "groupName": "react",
            "matchPackageNames": [
                "/^react.*/",
                "@types/react",
                "/^@types\\/react-.*/",
                "/^react-.*/"
            ]
        },
        {
            "groupName": "vue",
            "matchPackageNames": ["/^vue.*/"]
        },
        {
            "groupName": "eslint core",
            "matchPackageNames": ["eslint"]
        },
        {
            "groupName": "eslint ecosystem",
            "matchPackageNames": [
                "/^@eslint\\//",
                "/^@eslint-community\\//",
                "/^eslint-.*/"
            ]
        },
        {
            "groupName": "jasmine",
            "matchPackageNames": ["/^jasmine.*/"]
        },
        {
            "groupName": "@stylistic/*",
            "matchPackageNames": ["/^@stylistic\\//"]
        },
        {
            "groupName": "@angular-eslint/*",
            "matchPackageNames": ["/^@angular-eslint\\//"]
        },
        {
            "groupName": "@typescript-eslint/*",
            "matchPackageNames": ["/^@typescript-eslint\\//", "typescript-eslint"]
        },
        {
            "groupName": "typescript native preview",
            "matchPackageNames": ["@typescript/native-preview"]
        },
        {
            "groupName": "nx",
            "matchPackageNames": ["/^nx$/", "/^@nx\\//"],
            "postUpgradeTasks": {
                "commands": [
                    "sh -lc 'npx nx migrate nx@{{{newVersion}}} || true'",
                    "sh -lc 'NX_MIGRATE_SKIP_INSTALL=true npx nx migrate --run-migrations --ifExists || true'",
                    "sh -lc 'rm -f migrations.json'",
                    "sh -lc 'if [ -f package-lock.json ] && [ -f package.json ]; then if node -e \"const p=require(\\\"./package.json\\\");const w=p.workspaces;process.exit(Array.isArray(w)||Array.isArray(w&&w.packages)?0:1)\"; then npm install --package-lock-only --ignore-scripts --workspaces --include-workspace-root; else npm install --package-lock-only --ignore-scripts; fi; fi'"
                ],
                "executionMode": "branch",
                "fileFilters": ["**/*"]
            }
        },
        {
            "groupName": "@angular/*",
            "matchPackageNames": [
                "/^@angular\\//",
                "/^@angular-devkit\\//",
                "/^@schematics\\//",
                "ng-packagr"
            ],
            "postUpgradeTasks": {
                "commands": ["node -e \"const {readFileSync,rmSync}=require('node:fs');const {spawnSync}=require('node:child_process');const file=process.env.RENOVATE_POST_UPGRADE_COMMAND_DATA_FILE;if(!file)process.exit(0);const upgrades=JSON.parse(readFileSync(file,'utf8'));const targets=['@angular/core','@angular/cli','@angular/cdk'];for(const depName of targets){const u=upgrades.find(x=>x.depName===depName);if(!u||!u.newVersion)continue;const args=['nx','migrate',depName+'@'+u.newVersion];if(u.currentVersion)args.push('--from='+u.currentVersion);spawnSync('npx',args,{stdio:'inherit',shell:false});spawnSync('npx',['nx','migrate','--run-migrations','--ifExists'],{stdio:'inherit',shell:false,env:{...process.env,NX_MIGRATE_SKIP_INSTALL:'true'}});rmSync('migrations.json',{force:true});}\"", "sh -lc 'if [ -f package-lock.json ] && [ -f package.json ]; then if node -e \"const p=require(\\\"./package.json\\\");const w=p.workspaces;process.exit(Array.isArray(w)||Array.isArray(w&&w.packages)?0:1)\"; then npm install --package-lock-only --ignore-scripts --workspaces --include-workspace-root; else npm install --package-lock-only --ignore-scripts; fi; fi'"],
                "dataFileTemplate": "[{{#each upgrades}}{\"depName\":\"{{{depName}}}\",\"currentVersion\":\"{{{currentVersion}}}\",\"newVersion\":\"{{{newVersion}}}\"}{{#unless @last}},{{/unless}}{{/each}}]",
                "executionMode": "branch",
                "fileFilters": ["**/*"]
            },
            "separateMinorPatch": true
        },
        {
            "groupName": "@taiga-ui/design-tokens",
            "matchPackageNames": ["@taiga-ui/design-tokens"]
        },
        {
            "groupName": "@taiga-ui/configs",
            "matchPackageNames": ["@taiga-ui/configs"]
        },
        {
            "groupName": "@taiga-ui/*",
            "matchPackageNames": [
                "/^@taiga-ui\\//",
                "/^@ng-web-apis\\//",
                "!@taiga-ui/design-tokens",
                "!@taiga-ui/configs"
            ],
            "postUpgradeTasks": {
                "commands": ["node -e \"const {readFileSync,rmSync}=require('node:fs');const {spawnSync}=require('node:child_process');const file=process.env.RENOVATE_POST_UPGRADE_COMMAND_DATA_FILE;if(!file)process.exit(0);const upgrades=JSON.parse(readFileSync(file,'utf8'));const u=upgrades.find(x=>x.depName==='@taiga-ui/cdk');if(!u||!u.newVersion)process.exit(0);const args=['nx','migrate','@taiga-ui/cdk@'+u.newVersion];if(u.currentVersion)args.push('--from='+u.currentVersion);spawnSync('npx',args,{stdio:'inherit',shell:false});spawnSync('npx',['nx','migrate','--run-migrations','--ifExists'],{stdio:'inherit',shell:false,env:{...process.env,NX_MIGRATE_SKIP_INSTALL:'true'}});rmSync('migrations.json',{force:true});\"", "sh -lc 'if [ -f package-lock.json ] && [ -f package.json ]; then if node -e \"const p=require(\\\"./package.json\\\");const w=p.workspaces;process.exit(Array.isArray(w)||Array.isArray(w&&w.packages)?0:1)\"; then npm install --package-lock-only --ignore-scripts --workspaces --include-workspace-root; else npm install --package-lock-only --ignore-scripts; fi; fi'"],
                "dataFileTemplate": "[{{#each upgrades}}{\"depName\":\"{{{depName}}}\",\"currentVersion\":\"{{{currentVersion}}}\",\"newVersion\":\"{{{newVersion}}}\"}{{#unless @last}},{{/unless}}{{/each}}]",
                "executionMode": "branch",
                "fileFilters": ["**/*"]
            }
        },
        {
            "groupName": "stylelint dependencies",
            "matchPackageNames": [
                "stylelint",
                "/^postcss.*/",
                "/^@stylistic\\//",
                "/^stylelint.*/"
            ]
        },
        {
            "groupName": "ng-morph",
            "matchPackageNames": ["ng-morph"]
        },
        {
            "enabled": false,
            "matchDepTypes": ["engines"]
        },
        {
            "enabled": false,
            "matchPackageNames": ["/^typescript$/", "/^rxjs$/"],
            "matchUpdateTypes": ["major", "minor"]
        },
        {
            "enabled": false,
            "matchCurrentValue": "/^>=\\s*/",
            "matchDepTypes": ["peerDependencies", "optionalDependencies"]
        },
        {
            "enabled": false,
            "matchUpdateTypes": ["major"]
        },
        {
            "description": "Allow major updates for Taiga UI packages",
            "enabled": true,
            "matchPackageNames": [
                "/^@taiga-ui\\//",
                "/^@ng-web-apis\\//",
                "ng-morph"
            ],
            "matchUpdateTypes": ["major"]
        },
        {
            "description": "Allow all updates for Renovate",
            "enabled": true,
            "matchPackageNames": ["renovate", "/^@renovatebot\\//"],
            "matchUpdateTypes": [
                "major",
                "minor",
                "patch"
            ],
            "minimumReleaseAge": null
        },
        {
            "description": "Allow all GitHub Actions updates without quarantine",
            "enabled": true,
            "groupName": "Github Actions",
            "matchManagers": ["github-actions"],
            "matchUpdateTypes": [
                "major",
                "minor",
                "patch"
            ],
            "minimumReleaseAge": null
        }
    ],
    "postUpdateOptions": ["npmInstallTwice", "npmDedupe"],
    "postUpgradeTasks": {
        "commands": ["sh -lc 'if [ -f package-lock.json ] && [ -f package.json ]; then if node -e \"const p=require(\\\"./package.json\\\");const w=p.workspaces;process.exit(Array.isArray(w)||Array.isArray(w&&w.packages)?0:1)\"; then npm install --package-lock-only --ignore-scripts --workspaces --include-workspace-root; else npm install --package-lock-only --ignore-scripts; fi; fi'", "sh -lc 'npx lint-staged --allow-empty || true'"],
        "executionMode": "branch",
        "fileFilters": ["**/*"]
    },
    "prBodyColumns": [
        "Package",
        "Type",
        "Change"
    ],
    "prBodyTemplate": "{{{table}}}{{{notes}}}{{{changelogs}}}{{{controls}}}{{{footer}}}",
    "prConcurrentLimit": 3,
    "prHourlyLimit": 0,
    "rebaseWhen": "auto",
    "recreateWhen": "always",
    "repositoryCache": "enabled",
    "requireConfig": "optional",
    "rollbackPrs": true,
    "semanticCommits": "enabled",
    "separateMajorMinor": true,
    "separateMinorPatch": false,
    "skipInstalls": false,
    "suppressNotifications": ["configErrorIssue", "dependencyLookupWarnings"],
    "timezone": "Europe/Moscow"
}
